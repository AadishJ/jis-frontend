# Required in all environments (local + Vercel)
# Public base URL used by the frontend API client in lib/api.ts
NEXT_PUBLIC_API_URL=https://your-backend-api.example.com

# Optional for closed-case payment flow (client-side Razorpay test checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Optional: Selenium E2E test variables (not needed for Vercel runtime)
E2E_BASE_URL=http://localhost:3000
E2E_REGISTRAR_USER_ID=1
E2E_JUDGE_USER_ID=2
E2E_PASSWORD=pass
E2E_ELEMENT_TIMEOUT_MS=30000
E2E_TEST_TIMEOUT_MS=600000
E2E_DISABLE_WEB_SECURITY=true
SELENIUM_BROWSER=chrome
# SELENIUM_REMOTE_URL=http://localhost:4444/wd/hub
SELENIUM_HEADLESS=true
